# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=tourism_platform
DB_PORT=3306

# Server Configuration
NODE_ENV=development
PORT=3000
APP_NAME=TravEasy
JWT_SECRET=your_jwt_secret_here_min_32_chars_for_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Nodemailer - Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@travelasy.com
SMTP_SECURE=false

# SMS Configuration (Twilio) - 2FA
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
CMI_MERCHANT_ID=your_cmi_merchant_id
CMI_API_KEY=your_cmi_api_key

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Frontend URL
FRONTEND_URL=http://localhost:3001

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Security - Authentication & Authorization
BCRYPT_ROUNDS=12
PASSWORD_RESET_TIMEOUT=3600000
EMAIL_VERIFICATION_TIMEOUT=86400000
TWO_FACTOR_OTP_TIMEOUT=600000

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis Configuration (Optional - for caching/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS Configuration (Optional - for S3 file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
